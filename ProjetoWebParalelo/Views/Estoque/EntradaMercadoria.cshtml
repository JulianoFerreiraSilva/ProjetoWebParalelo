@model Modelo.Cadastro.EntradaMercadoria

@{
    ViewData["Title"] = "EntradaMercadoria";
}

<h1>EntradaMercadoria</h1>

<h4>EntradaMercadoria</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="EntradaMercadoria">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="ProdutoId" class="control-label"></label>
                <select asp-for="ProdutoId" class ="form-control" asp-items="ViewBag.ProdutoId"></select>
            </div>
            <div class="form-group">
                <label asp-for="Produto.Nome" class="control-label"></label>
                <select asp-for="Produto.Nome" class="form-control" asp-items="@(new SelectListItem)"></select>
            </div>
            <div class="form-group">
                <label asp-for="EstoqueId" class="control-label"></label>
                <select asp-for="EstoqueId" class ="form-control" asp-items="ViewBag.EstoqueId"></select>
            </div>
            <div class="form-group">
                <label asp-for="FornecedorId" class="control-label"></label>
                <select asp-for="FornecedorId" class ="form-control" asp-items="ViewBag.FornecedorId"></select>
            </div>
            <div class="form-group">
                <label asp-for="ValorTotal" class="control-label"></label>
                <input asp-for="ValorTotal" class="form-control" />
                <span asp-validation-for="ValorTotal" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
